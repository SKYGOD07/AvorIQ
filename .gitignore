# ============================================
# AvorIQ-Lab — Project .gitignore
# For USAII Hackathon Submission
# ============================================

# ── Dependencies ──
node_modules/
**/node_modules/

# ── Next.js Build ──
.next/
**/.next/
out/

# ── Environment Files ──
.env
.env.*
!.env.example

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── IDE / Editor ──
.vscode/
.idea/
*.code-workspace

# ── Large Binary Files (NOT for Git) ──
*.exe
*.msi
*.dmg
*.zip
*.tar.gz
*.rar

# ── AI Tools / Local Dev Utilities ──
ai-tools/
opencode.cmd
opencode.ps1
gemini.cmd
gemini.ps1

# ── Design Reference Images (local only) ──
Desgin to copy from/

# ── Ollama Local Model Weights ──
ollama-models/blobs/
ollama-models/manifests/

# ── Docker Persistent Volumes ──
docker-data/
postgres/
avoriq/backend/data/

# ── Backups (local only) ──
backups/

# ── N8N root-level (local Docker data) ──
/n8n/

# ── Python ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Coverage / Testing ──
coverage/
.nyc_output/

# ── Misc ──
*.tsbuildinfo
next-env.d.ts

# ── User Specific ──
changes_summary.md

